{
  "name": "mantra",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "onboarding": "npm run setup && npm run validate",
    "onboarding:full": "npm run setup && npm run validate && npm run sync:codex",
    "onboarding:json": "npm run setup -- --json && npm run validate:json",
    "onboarding:full:json": "npm run setup -- --json && npm run validate:json && npm run sync:codex:json",
    "sync:codex": "tsx scripts/sync-agents-to-codex.ts && tsx scripts/sync-rules-to-codex.ts",
    "sync:codex:json": "npm run sync:codex:agents -- --json && npm run sync:codex:rules -- --json",
    "sync:codex:agents": "tsx scripts/sync-agents-to-codex.ts",
    "sync:codex:rules": "tsx scripts/sync-rules-to-codex.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"scripts/**/*.ts\" \"tests/**/*.ts\" --max-warnings=0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run tests/agents.test.ts tests/rules.test.ts tests/contracts/cli-json-contract.test.ts tests/contracts/package-scripts-contract.test.ts tests/contracts/content-precedence.test.ts tests/contracts/name-conflict-contract.test.ts",
    "smoke:onboarding": "vitest run tests/smoke/onboarding.test.ts",
    "validate:agents": "tsx scripts/validate-agents.ts",
    "validate:rules": "tsx scripts/validate-rules.ts",
    "validate:json": "npm run validate:agents -- --json && npm run validate:rules -- --json",
    "validate": "npm run validate:agents && npm run validate:rules",
    "prepare": "husky"
  },
  "lint-staged": {
    "agents/*.md": [
      "npm run validate:agents"
    ],
    "rules/*.md": [
      "npm run validate:rules"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.2.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
